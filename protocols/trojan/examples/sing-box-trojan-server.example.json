{
  "log": {
    "level": "warn",
    "timestamp": true
  },
  "inbounds": [
    {
      "type": "trojan",
      "tag": "trojan-in",
      "listen": "::",
      "listen_port": 12443,
      "users": [
        {
          "name": "trojan-user",
          "password": "CHANGE_ME"
        }
      ],
      "tls": {
        "enabled": true,
        "certificate_path": "/etc/sing-box-trojan/certs/cert.pem",
        "key_path": "/etc/sing-box-trojan/certs/private.key",
        "min_version": "1.2"
      }
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "final": "direct"
  }
}
